# ============================================================
# DeepSeek RAG 知识库 — 环境变量配置文件
# 使用说明：复制此文件为 .env 并填入真实密钥
#   cp .env.example .env
# ============================================================

# ======================================================================
# 一、模型提供商选择（核心切换开关）
# ======================================================================
# deepseek : 问答用 DeepSeek，无预处理（默认）
# qwen     : 问答用千问，无预处理
# hybrid   : 预处理用千问 + 问答用 DeepSeek（多模型协同，推荐）
# ======================================================================
LLM_PROVIDER=deepseek

# 预处理模型（可选，独立覆盖。优先级高于 LLM_PROVIDER=hybrid 的推断）
# 留空表示跟随 LLM_PROVIDER 自动判断
# PREPROCESS_PROVIDER=qwen

# ======================================================================
# 二、DeepSeek API（LLM_PROVIDER=deepseek 或 hybrid 时必填）
# ======================================================================
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# deepseek-chat → DeepSeek-V3（性价比高）
# deepseek-reasoner → DeepSeek-R1（深度推理）
DEEPSEEK_CHAT_MODEL=deepseek-chat

# ======================================================================
# 三、通义千问 API（LLM_PROVIDER=qwen 或 hybrid 时必填）
# ======================================================================
QWEN_API_KEY=sk-your-qwen-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 问答模型: qwen-turbo（快速）/ qwen-plus（均衡）/ qwen-max（最强）
QWEN_CHAT_MODEL=qwen-plus
# 预处理模型: 推荐用 turbo 降低成本
QWEN_PREPROCESS_MODEL=qwen-turbo

# ======================================================================
# 四、Embedding 模型
# ======================================================================
# 中英文混合：paraphrase-multilingual-MiniLM-L12-v2（384维）
# 纯中文　　：BAAI/bge-small-zh-v1.5（512维）
LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# 运行设备: cpu / cuda / mps
EMBEDDING_DEVICE=cpu

# ======================================================================
# 五、文档切片参数
# ======================================================================
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ======================================================================
# 六、检索参数
# ======================================================================
TOP_K=5

# ======================================================================
# 七、HuggingFace 镜像（国内用户必填）
# ======================================================================
HF_ENDPOINT=https://hf-mirror.com

# ======================================================================
# 八、存储路径
# ======================================================================
KB_STORAGE_PATH=./kb_storage
